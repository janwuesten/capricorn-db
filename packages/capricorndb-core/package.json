{
  "name": "@janwuesten/capricorndb-core",
  "version": "0.1.0",
  "author": "Jan Wüsten",
  "description": "The core package of the Capricorn NoSQL database. It contains the core functionality and types.",
  "repository": {
    "type": "git",
    "url": "https://github.com/janwuesten/capricorn-db"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc && tsc-alias --resolve-full-paths",
    "prepack": "pnpm build",
    "lint": "eslint src"
  },
  "keywords": [
    "nosql",
    "database",
    "effect",
    "typescript"
  ],
  "devDependencies": {
    "@janwuesten/eslint-config": "workspace:*",
    "@types/node": "^25.8.0",
    "eslint": "^9.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  },
  "types": "dist/index.d.ts"
}
